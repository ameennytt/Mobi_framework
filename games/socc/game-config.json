{
  "gameId": "soccer",
  "version": "1.0.0",
  "supportsTv": true,
  "supportsMobile": true,
  "supportsMotion": false,
  "enableEnrichment": false,

  "hud": "versus",
  "field": "goal",

  "theme": {
    "--game-primary": "#0a0e1a",
    "--game-accent": "#ff6b00",
    "--game-text": "#fff8f0",
    "--game-muted": "#a89080",
    "--game-success": "#00e676",
    "--game-font": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
  },

  "assets": {
    "APP_LOGO": "/games/soccer/assets/logo1.svg",
    "SCREEN_HERO": "/games/soccer/assets/icon1.svg"
  },

  "text": {
    "APP_TITLE": "Goal Rush",
    "PRIMARY_SCORE": "Goals",
    "SECONDARY_SCORE": "Saves",
    "PROGRESS_METRIC": "Round",
    "ACTIVITY_FEED": "Match Feed",
    "RESULT_PANEL": "Full Time",
    "START_ACTION": "KICK OFF",
    "EXIT_ACTION": "QUIT"
  },

  "teams": [
    { "name": "Inferno FC",    "short": "INF", "color": "#ff3c00" },
    { "name": "Frost United",  "short": "FRS", "color": "#00c8ff" },
    { "name": "Venom City",    "short": "VNM", "color": "#aaff00" },
    { "name": "Night Ravens",  "short": "NIT", "color": "#9b59b6" },
    { "name": "Solar Strikers","short": "SOL", "color": "#ffcf00" },
    { "name": "Iron Coast",    "short": "IRN", "color": "#78909c" }
  ],

  "formats": [
    { "id": "f3", "name": "Quick",    "sub": "3 penalties", "rounds": 3 },
    { "id": "f5", "name": "Match",    "sub": "5 penalties", "rounds": 5 },
    { "id": "f7", "name": "Shootout", "sub": "7 penalties", "rounds": 7 }
  ],

  "flow": [
    { "type": "pair" },
    { "type": "choice", "key": "team",   "title": "Pick your club",   "source": "teams" },
    { "type": "choice", "key": "format", "title": "Match length",     "source": "formats" },
    { "type": "ceremony", "kind": "kickoff" },
    { "type": "briefing" }
  ]
}
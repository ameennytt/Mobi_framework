{
  "gameId": "cricswing",
  "version": "1.0.0",
  "supportsTv": true,
  "supportsMobile": true,
  "supportsMotion": false,
  "input": "buttons",
  "enableEnrichment": false,
  "_comment_home": "Phone front door (FrameworkHome). Menu auto-builds from ui.help/about/settings; splash shows the logo briefly on open. Add home.items to customize.",
  "home": { "splash": true },
  "_comment_preset": "BROADCAST preset — shows the full CricSwing-style experience: onboarding, mode hub, series, toss, roster, TV intro/countdown/over-summary/milestones. A minimal game omits the ui/tv/series blocks (see games/starter).",
  "_comment_code": "Modular game code, loaded in order (entry index.js last). chase-shot.js = cricket ball math.",
  "code": [
    "chase-shot.js",
    "gameplay/rules.js",
    "gameplay/scoring.js",
    "gameplay/visuals.js",
    "gameplay/index.js"
  ],
  "assets": {
    "APP_LOGO": "/games/cricswing/assets/cricswing-logo.png",
    "APP_ICON": "/games/cricswing/assets/icon.svg",
    "SCREEN_HERO": "/games/cricswing/assets/cricswing-mark.png",
    "SCREEN_BACKGROUND": "#000"
  },
  "text": {
    "APP_TITLE": "CricSwing",
    "APP_TITLE_HTML": "Cric<span class=\"fw-accent\">Swing</span>",
    "APP_TAGLINE": "TV CRICKET",
    "PRIMARY_SCORE": "Runs",
    "SECONDARY_SCORE": "Wickets",
    "PROGRESS_METRIC": "Overs",
    "ACTIVITY_FEED": "Match Feed",
    "RESULT_PANEL": "Result",
    "START_ACTION": "BAT NOW",
    "EXIT_ACTION": "QUIT"
  },
  "_comment_ui": "OPTIONAL onboarding + info modals. Remove this block for a no-onboarding game.",
  "ui": {
    "onboarding": {
      "consent": {
        "title": "Help improve the game?",
        "body": "Allow anonymous gameplay data to be collected (no name, no email). You can change this later.",
        "acceptText": "Allow",
        "declineText": "No thanks"
      },
      "intro": [
        { "art": "phone", "title": "Your phone is the bat", "text": "Hold the phone like a bat handle.<br>Tilt it — the bat on the TV tilts <b>with you</b>." },
        { "art": "timing", "title": "Time the swing", "text": "Watch the bowler. When the timing bar hits the <b>green zone</b>, swing your phone forward." },
        { "art": "lock", "title": "Lock your stance", "text": "Before the first ball, tap <b>LOCK MY STANCE</b> to calibrate the bat to your grip." }
      ]
    },
    "about": {
      "title": "About Chase Arena",
      "body": [
        "An independent cricket-inspired game built on the TV + phone framework.",
        "Teams and names are fictional or user-customized."
      ]
    },
    "help": {
      "title": "How to Play",
      "body": [
        "1. Pair your phone with the TV using the on-screen code.",
        "2. Pick a mode, team, format and difficulty.",
        "3. Choose a shot direction and tap PLAY SHOT to chase the target."
      ]
    },
    "settings": [
      { "label": "Sound", "type": "toggle", "value": true },
      { "label": "Mirror to TV", "type": "toggle", "value": true }
    ]
  },
  "_comment_series": "OPTIONAL — a format can set seriesType to start a multi-match series/tournament.",
  "rosterTitle": "Your batting order",
  "roster": [
    { "name": "Opener 1", "role": "BAT" },
    { "name": "Opener 2", "role": "BAT" },
    { "name": "No. 3", "role": "BAT" },
    { "name": "No. 4", "role": "ALL-R" },
    { "name": "Finisher", "role": "ALL-R" }
  ],
  "tv": {
    "intro": true,
    "countdown": 3,
    "milestones": true,
    "overSummary": true,
    "broadcast": "full"
  },
  "modes": [
    { "id": "cup", "branch": "cup", "title": "Chase World Cup", "sub": "National teams · Tournament climb", "iconUrl": "/games/cricswing/assets/icons/art-menu-1.svg", "accent": "match" },
    { "id": "league", "branch": "league", "title": "Chase League", "sub": "City clubs · Local rivalries", "iconUrl": "/games/cricswing/assets/icons/art-menu-2.svg", "accent": "practice" },
    { "id": "featured", "title": "Featured Chase", "sub": "🔒 Win on Hard to unlock 100 chase levels.", "iconUrl": "/games/cricswing/assets/icons/art-menu-3.svg", "locked": true }
  ],

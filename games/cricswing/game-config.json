  ],
  "hud": "chase",
  "arena": "cricket",
  "_comment_controller": "Framework-owned controller. groups=aim (LEG/STRAIGHT/OFF); PLAY SHOT sends {choice}. gameplay/controller.js supplies the chase Need calc, the series target re-deal and the broadcast match-end branching.",
  "controller": {
    "code": ["gameplay/controller.js"],
    "hud": [
      { "key": "runs", "label": "Runs" },
      { "key": "need", "label": "Need" }
    ],
    "groups": [
      { "key": "choice", "options": [
        { "id": "left", "label": "LEG" },
        { "id": "center", "label": "STRAIGHT", "default": true },
        { "id": "right", "label": "OFF" }
      ] }
    ],
    "actions": [
      { "id": "go", "label": "PLAY SHOT", "primary": true }
    ],
    "hint": "Pick a direction, then tap PLAY SHOT",
    "tips": [
      { "icon": "🏏", "title": "Pick your shot", "text": "Choose LEG, STRAIGHT or OFF before each ball — it sets where you aim." },
      { "icon": "⏱️", "title": "Play the shot", "text": "Tap PLAY SHOT as the ball comes in. Good timing scores boundaries." },
      { "icon": "🎯", "title": "Chase the target", "text": "Beat the target before you run out of balls or wickets." }
    ]
  },
  "_comment_flow": "Lobby steps. Framework builds these screens; reorder/remove freely. consent/intro are one-time (skipped after first run). menu = mode hub with About/Help entries.",
  "flow": [
    { "type": "pair" },
    { "type": "consent" },
    { "type": "intro" },
    {
      "type": "menu",
      "key": "mode",
      "title": "Pick your mode",
      "kicker": "Step 1",
      "sub": "All games run on classic T20 rules.",
      "source": "modes",
      "branch": true,
      "entries": [
        { "icon": "📖", "label": "How to Play", "action": "help" },
        { "icon": "ℹ️", "label": "About", "action": "about" }
      ]
    },
    { "type": "choice", "key": "team", "title": "Pick your team", "kicker": false, "source": "teams", "when": { "key": "branch", "equals": "team" } },
    { "type": "choice", "key": "team", "title": "Pick your country", "kicker": false, "tile": true, "tileSub": "Test Nation", "source": "chaseData.cup", "when": { "key": "branch", "equals": "cup" } },
    { "type": "choice", "key": "league", "title": "Pick your league", "kicker": false, "layout": "rows", "source": "chaseData.leagues", "when": { "key": "branch", "equals": "league" } },
    { "type": "choice", "key": "team", "title": "Pick your club", "kicker": false, "tile": true, "tileSub": "Club", "source": "$league.teams", "when": { "key": "branch", "equals": "league" } },
    { "type": "choice", "key": "format", "title": "Pick your format", "kicker": "Step 2", "layout": "list", "context": "team", "source": "formats" },
    { "type": "choice", "key": "difficulty", "title": "Pick your challenge", "kicker": "Step 3", "source": "difficulties", "cols": 3, "preview": true, "confirm": true, "confirmText": "Start Match" },
    { "type": "ceremony", "kind": "toss", "kicker": "Step 4" },
    { "type": "stance" },
    { "type": "target" }
  ]
}

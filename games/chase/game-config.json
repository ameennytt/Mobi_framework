{
  "gameId": "chase",
  "version": "1.0.0",
  "supportsTv": true,
  "supportsMobile": true,
  "supportsMotion": false,
  "enableEnrichment": false,
  "_comment_code": "Modular game code, loaded in order (entry index.js last). chase-shot.js = cricket ball math.",
  "code": [
    "chase-shot.js",
    "gameplay/rules.js",
    "gameplay/scoring.js",
    "gameplay/visuals.js",
    "gameplay/index.js"
  ],
  "assets": {
    "APP_LOGO": "/games/chase/assets/logo1.svg",
    "SCREEN_HERO": "/games/chase/assets/icon1.svg",
    "SCREEN_BACKGROUND": "radial-gradient(ellipse at 50% 0%, #0d1830 0%, #060a14 100%)"
  },
  "text": {
    "APP_TITLE": "Chase Arena",
    "PRIMARY_SCORE": "Runs",
    "SECONDARY_SCORE": "Wickets",

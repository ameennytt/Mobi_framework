{
  "gameId": "chase",
  "version": "1.0.0",
  "supportsTv": true,
  "supportsMobile": true,
  "supportsMotion": false,
  "input": "buttons",
  "enableEnrichment": false,
  "_comment_preset": "BROADCAST preset — shows the full CricSwing-style experience: onboarding, mode hub, series, toss, roster, TV intro/countdown/over-summary/milestones. A minimal game omits the ui/tv/series blocks (see games/starter).",
  "_comment_code": "Modular game code, loaded in order (entry index.js last). chase-shot.js = cricket ball math.",
  "code": [
    "chase-shot.js",
    "gameplay/rules.js",
    "gameplay/scoring.js",
    "gameplay/visuals.js",
    "gameplay/index.js"
  ],
  "assets": {
    "APP_LOGO": "/games/chase/assets/logo1.svg",
    "SCREEN_HERO": "/games/chase/assets/icon1.svg",
    "SCREEN_BACKGROUND": "radial-gradient(ellipse at 50% 0%, #0d1830 0%, #060a14 100%)"
  },
  "text": {
    "APP_TITLE": "Chase Arena",
    "APP_TAGLINE": "TV CRICKET",
    "PRIMARY_SCORE": "Runs",
    "SECONDARY_SCORE": "Wickets",
    "PROGRESS_METRIC": "Overs",
    "ACTIVITY_FEED": "Match Feed",
    "RESULT_PANEL": "Result",
    "START_ACTION": "PLAY",
    "EXIT_ACTION": "QUIT"
  },
  "_comment_ui": "OPTIONAL onboarding + info modals. Remove this block for a no-onboarding game.",
  "ui": {
    "onboarding": {
      "consent": {
        "title": "Help improve the game?",
        "body": "Allow anonymous gameplay data to be collected (no name, no email). You can change this later.",
        "acceptText": "Allow",
        "declineText": "No thanks"
      },
      "intro": [
        { "icon": "📱", "title": "Your phone is the bat", "text": "Pick a shot direction, then tap to play it. The TV is your big screen." },
        { "icon": "🎯", "title": "Chase the target", "text": "The opponent sets a score. Beat it before you run out of balls or wickets." },
        { "icon": "🏆", "title": "Climb the modes", "text": "Play a friendly, win a Best-of-3 series, or take on a knockout." }
      ]
    },
    "about": {
      "title": "About Chase Arena",
      "body": [
        "An independent cricket-inspired game built on the TV + phone framework.",
        "Teams and names are fictional or user-customized."
      ]
    },
    "help": {
      "title": "How to Play",
      "body": [
        "1. Pair your phone with the TV using the on-screen code.",
        "2. Pick a mode, team, format and difficulty.",
        "3. Choose a shot direction and tap PLAY SHOT to chase the target."
      ]
    },
    "settings": [
      { "label": "Sound", "type": "toggle", "value": true },
      { "label": "Mirror to TV", "type": "toggle", "value": true }
    ]
  },
  "_comment_series": "OPTIONAL — a format can set seriesType to start a multi-match series/tournament.",
  "rosterTitle": "Your batting order",
  "roster": ["Opener 1", "Opener 2", "No. 3", "No. 4", "No. 5"],
  "tv": {
    "intro": true,
    "countdown": 3,
    "milestones": true,
    "overSummary": true
  },
  "modes": [
    { "id": "cup", "branch": "cup", "title": "Chase Cup", "sub": "National teams · tournament climb" },
    { "id": "league", "branch": "league", "title": "Chase League", "sub": "City clubs · local rivalries" },
    { "id": "quick", "branch": "quick", "title": "Quick Play", "sub": "Jump straight in" }
  ],
  "teams": [
    { "name": "Red Lions", "short": "RED", "color": "#e0443e" },
    { "name": "Blue Sharks", "short": "BLU", "color": "#3a7bd5" },
    { "name": "Green Bolts", "short": "GRN", "color": "#2faa55" },
    { "name": "Gold Hawks", "short": "GLD", "color": "#e0a83e" },
    { "name": "Purple Storm", "short": "PUR", "color": "#8e44ad" },
    { "name": "Teal Tigers", "short": "TEA", "color": "#16a89a" }
  ],
  "chaseData": {
    "cup": ["Northland", "Southport", "Eastfield", "Westbay", "Highvale", "Riverton"],
    "leagues": [
      { "name": "Metro League", "teams": ["Downtown", "Harbor", "Uptown", "Midtown"] },
      { "name": "Coast League", "teams": ["Bayside", "Cliffend", "Sandar", "Tidewater"] }
    ]
  },
  "formats": [
    { "id": "f1", "name": "Friendly", "sub": "1 over · quick", "overs": 1 },
    { "id": "f2", "name": "Series", "sub": "Best of 3 · 2 overs", "overs": 2, "seriesType": "series", "bestOf": 3 },
    { "id": "f5", "name": "Tournament", "sub": "Knockout · 2 overs", "overs": 2, "seriesType": "tournament", "total": 3 }
  ],
  "difficulties": [
    { "id": "easy", "name": "Easy", "sub": "Relaxed chase" },
    { "id": "medium", "name": "Medium", "sub": "Balanced" },
    { "id": "hard", "name": "Hard", "sub": "Steep target" }
  ],
  "hud": "chase",
  "_comment_flow": "Lobby steps. Framework builds these screens; reorder/remove freely. consent/intro are one-time (skipped after first run). menu = mode hub with About/Help entries.",
  "flow": [
    { "type": "pair" },
    { "type": "consent" },
    { "type": "intro" },
    {
      "type": "menu",
      "key": "mode",
      "title": "Pick your mode",
      "source": "modes",
      "branch": true,
      "entries": [
        { "icon": "📖", "label": "How to Play", "action": "help" },
        { "icon": "ℹ️", "label": "About", "action": "about" }
      ]
    },
    { "type": "choice", "key": "team", "title": "Pick your team", "source": "teams", "when": { "key": "branch", "equals": "team" } },
    { "type": "choice", "key": "team", "title": "Pick your team", "source": "chaseData.cup", "when": { "key": "branch", "equals": "cup" } },
    { "type": "choice", "key": "league", "title": "Pick your league", "source": "chaseData.leagues", "when": { "key": "branch", "equals": "league" } },
    { "type": "choice", "key": "team", "title": "Pick your club", "source": "$league.teams", "when": { "key": "branch", "equals": "league" } },
    { "type": "choice", "key": "format", "title": "Pick your format", "source": "formats" },
    { "type": "choice", "key": "difficulty", "title": "Pick your challenge", "source": "difficulties" },
    { "type": "ceremony", "kind": "toss" },
    { "type": "target" }
  ]
}
